# Optional. CodeAtlas works without this key and falls back to deterministic graph search.
OPENAI_API_KEY=

# Optional. Public GitHub analysis works without this token, but authenticated
# requests have higher GitHub API rate-limit headroom for local demos.
GITHUB_TOKEN=

# Optional. Comma-separated browser origins allowed by backend CORS in deployment.
CODEATLAS_ALLOWED_ORIGINS=

# Optional abuse-boundary tuning. Defaults are safe for the MVP.
CODEATLAS_ANALYZE_RATE_LIMIT=10
CODEATLAS_ANALYZE_RATE_WINDOW_SECONDS=600
CODEATLAS_QUESTION_QUOTA=50
CODEATLAS_AI_QUOTA=10
CODEATLAS_LIMITER_MAX_TRACKED_ANALYSES=256
CODEATLAS_TRUST_X_FORWARDED_FOR=false
